{
    "name": "hardimpact/openclaw-sdk-laravel",
    "description": "Laravel SDK for the OpenClaw AI agent gateway — health checks, wake management, and status tracking",
    "keywords": [
        "hardimpact",
        "laravel",
        "openclaw",
        "ai",
        "gateway",
        "sdk"
    ],
    "homepage": "https://github.com/hardimpactdev/openclaw-sdk-laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Nick Kartel",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "amphp/websocket-client": "^2.0",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0",
        "illuminate/database": "^11.0||^12.0",
        "illuminate/http": "^11.0||^12.0",
        "illuminate/support": "^11.0||^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "HardImpact\\OpenClaw\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HardImpact\\OpenClaw\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "lint": "vendor/bin/pint",
        "rector": "vendor/bin/rector",
        "check": "composer test && composer analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HardImpact\\OpenClaw\\OpenClawServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
